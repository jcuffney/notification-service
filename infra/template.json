{
    "AWSTemplateFormatVersion": "2010-09-09",
    "Parameters": {
        "DomainName": {
            "Type": "AWS::SSM::Parameter::Value<String>",
            "Default": "/cuffney/main/domain",
            "Description": "The ID of the Route 53 hosted zone"
        }
    },
    "Resources": {
        "SESIdentity": {
            "Type": "AWS::SES::EmailIdentity",
            "Properties": {
                "EmailIdentity": {
                    "Fn::Sub": "no-reply@${DomainName}"
                }
            }
        }
    }
}